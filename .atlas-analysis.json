  "keyFeatures": [
    "Multi-provider LLM routing with OpenAI-compatible API",
    "Real-time usage tracking and cost analytics",
    "Response caching with Redis for improved performance",
    "Guardrails for content filtering and safety",
    "Web search and tool calling capabilities",
    "Image generation and vision support",
    "Self-hosting with Docker deployment",
    "API key management and rate limiting",
    "Anthropic and OpenAI endpoint compatibility",
    "MCP (Model Context Protocol) support"
  ],
  "publicApiSurface": [
    "POST /v1/chat/completions - Chat completion with streaming support",
    "POST /v1/messages - Anthropic-compatible messages endpoint",
    "GET /v1/models - List available models",
    "POST /v1/images/generations - Generate images",
    "GET /health - Health check endpoint",
    "GET /metrics - Prometheus metrics"
  ]
